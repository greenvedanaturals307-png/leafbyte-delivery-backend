# ── Copy this file to ".env" and fill in real values ──────────────
# NEVER commit the real .env file or share it. These are secrets.

# Your Shiprocket login (create a free account at https://www.shiprocket.in)
# Tip: create a dedicated API user under Settings > API > Configure
SHIPROCKET_EMAIL=you@example.com
SHIPROCKET_PASSWORD=your-shiprocket-password

# The pickup location nickname you set in Shiprocket (Settings > Pickup Addresses).
# "Primary" is the default Shiprocket gives the first address.
SHIPROCKET_PICKUP_LOCATION=Primary

# The PIN code of your pickup/warehouse address (used for delivery estimates).
# 335063 = Sangaria, Hanumangarh, Rajasthan. Change if yours differs.
SHIPROCKET_PICKUP_PINCODE=335063

# Which website origins are allowed to call this backend.
# Use your live site, e.g. https://leafbyte.com . Comma-separate multiple.
# Leave as * only while testing locally.
ALLOWED_ORIGINS=*

# Port to run on locally
PORT=3000
